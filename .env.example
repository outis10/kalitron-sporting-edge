# ============================================================
# KALITRON SPORTING EDGE — Environment Configuration
# Copy to .env and fill in your values
# ============================================================

# === LLM (Anthropic Claude) ===
ANTHROPIC_API_KEY=sk-ant-...

# === Football Data API ===
# Get free key at: https://www.api-football.com/
API_FOOTBALL_KEY=your_api_football_key_here
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io

# === Polymarket Credentials (only needed for real trading) ===
POLYMARKET_PRIVATE_KEY=0x...
POLYMARKET_FUNDER_ADDRESS=0x...

# L2 API credentials — leave blank to auto-derive from PRIVATE_KEY on first run
# (derivation takes ~2s; set these after first run to skip it)
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# Signature type: 0=EOA/MetaMask  1=Magic/email  2=Gnosis Safe proxy
# Most users with a regular wallet use 0
POLYMARKET_SIGNATURE_TYPE=0

# === Database ===
DATABASE_URL=postgresql+asyncpg://sporting:edge@localhost:5432/sporting_edge
DATABASE_URL_SYNC=postgresql://sporting:edge@localhost:5432/sporting_edge

# === Safety Switches ===
# CRITICAL: Keep PAPER_TRADING=true until model is validated
PAPER_TRADING=true
EXECUTE_TRADES=false

# === Risk Parameters ===
BANKROLL_USD=1000.0
MAX_KELLY_FRACTION=0.25        # Full Kelly × 0.25 = Quarter Kelly
MAX_BET_PCT_BANKROLL=0.02      # Max 2% of bankroll per bet
MIN_EV_THRESHOLD=0.05              # Paper trading / backtesting
MIN_EV_THRESHOLD_LIVE=0.08         # Production: absorbs spread + slippage + model error
MIN_EV_THRESHOLD_LOW_LIQUIDITY=0.12  # Markets with liquidity between MIN_MARKET_LIQUIDITY and LOW_LIQUIDITY_THRESHOLD
LOW_LIQUIDITY_THRESHOLD=10000.0    # Markets below this get stricter EV threshold in live mode
MIN_MARKET_LIQUIDITY=5000.0        # Min $5k liquidity to consider market
MIN_MODEL_CONFIDENCE=0.6       # Min model confidence score (0-1)
DAILY_LOSS_LIMIT_USD=50.0      # Stop trading if daily loss exceeds this

# === Leagues to Monitor ===
ACTIVE_LEAGUES=39,140,2         # 39=Premier League, 140=La Liga, 2=Champions League (API-Football IDs)

# === Position Management ===
TAKE_PROFIT_PCT=0.10            # Close position at +10% price gain vs entry
STOP_LOSS_PCT=0.05              # Close position at -5% price drop vs entry
LINEUP_CHECK_MINUTES_BEFORE_KICKOFF=65  # Stage 1: fetch lineups + recalc EV, close if edge gone
FORCE_CLOSE_MINUTES_BEFORE_KICKOFF=30   # Stage 2: unconditional force-close before kickoff

# === Scheduler ===
DATA_REFRESH_MINUTES=30         # How often to fetch new match data
SIGNAL_SCAN_MINUTES=15          # How often to scan for new EV opportunities
POSITION_CHECK_MINUTES=5        # How often to check open positions (TP/SL/force-close)

# === Telegram Notifications (optional) ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === Logging ===
LOG_LEVEL=INFO
LOG_FORMAT=json                  # "json" or "pretty"

# === LangSmith Tracing (optional) ===
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=sporting-edge

# === App ===
ENVIRONMENT=development          # "development" | "production"
API_HOST=0.0.0.0
API_PORT=8001
